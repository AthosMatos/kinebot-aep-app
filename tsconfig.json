{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./src/*"],
			"@/assets/*": ["./assets/*"],
			"@root/*": ["./*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts", "nativewind-env.d.ts"],
	"exclude": ["node_modules", "src/app/(protected)/(tabs)/analyses/modals/analysesFilter/useFilterModal.ts"]
}
